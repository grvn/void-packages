# ---------------------------------------------------------
# GitHub Linguist configuration
# Force the file named "template" or ".template" to be treated as Bash
# ---------------------------------------------------------
{template,.template} linguist-language=bash

# ---------------------------------------------------------
# Whitespace rules for diff/patch files
# Disable warnings for:
#   - space-before-tab
#   - trailing whitespace
# These file types often contain literal whitespace that
# must remain unchanged
# ---------------------------------------------------------
*.{diff,patch} whitespace=-space-before-tab,-trailing-space
